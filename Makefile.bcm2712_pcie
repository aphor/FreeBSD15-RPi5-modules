.PATH: ${.CURDIR}
KMOD=	bcm2712_pcie
SRCS=	bcm2712_pcie.c

# Symbols exported for use by rp1_eth.ko
EXPORT_SYMS=	bcm2712_pcie_register_rp1_intr bcm2712_pcie_deregister_rp1_intr bcm2712_pcie_gem_iack

# Auto-generated interface headers
SRCS+=	device_if.h bus_if.h acpi_if.h opt_acpi.h opt_global.h

# System include directories
CFLAGS+= -I/usr/src/sys -I/usr/src/sys/contrib/libfdt
CFLAGS+= -I/usr/src/sys/contrib/dev/acpica/include

.include <bsd.kmod.mk>
